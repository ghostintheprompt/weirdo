{
  "name": "weirdo",
  "version": "1.0.0",
  "description": "Live microphone level monitor for macOS",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac dmg"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.weirdo.app",
    "productName": "Weirdo",
    "mac": {
      "category": "public.app-category.music",
      "target": [
        { "target": "dmg", "arch": ["arm64"] }
      ],
      "icon": "assets/icon.icns",
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "title": "Weirdo",
      "window": { "width": 540, "height": 380 }
    },
    "files": [
      "main.js",
      "index.html",
      "assets/**"
    ]
  }
}
